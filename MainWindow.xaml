<Window x:Class="FileExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FileExplorer.Controls"
        xmlns:loc="clr-namespace:FileExplorer.Markup"
        xmlns:helpers="clr-namespace:FileExplorer.Helpers"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        x:Name="RootWindow"
        Title="provix"
        Width="1100"
        Height="680"
        MinWidth="720"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Window-only chrome styles (palette comes from active theme dictionary) -->

        <!-- Navigation buttons -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="{DynamicResource ButtonChromeBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard Storyboard="{StaticResource ButtonHoverInStoryboard}" />
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard Storyboard="{StaticResource ButtonHoverOutStoryboard}" />
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseDown">
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressInStoryboard}" />
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseUp">
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressOutStoryboard}" />
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Address / search bar style is in ExplorerTheme.xaml -->

        <!-- Settings tab buttons -->
        <Style x:Key="SettingsTabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DialogButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="selected">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SelectionFillBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dialog / overlay action buttons -->
        <Style x:Key="DialogActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Background" Value="{DynamicResource DialogButtonBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard Storyboard="{StaticResource ButtonHoverInStoryboard}" />
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard Storyboard="{StaticResource ButtonHoverOutStoryboard}" />
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseDown">
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressInStoryboard}" />
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseUp">
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressOutStoryboard}" />
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DialogButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource DialogDangerBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DialogDangerHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DialogDangerPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogDeleteCommitButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogActionButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFF9A9A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#44FF6B6B" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#88FF6B6B" />
                                <Setter Property="Foreground" Value="#FFFFECEC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DialogDangerPressedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Editor chrome -->
        <Style x:Key="EditorActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogActionButtonStyle}">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="helpers:SmoothScrollHelper.IsEnabled" Value="True" />
            <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="SelectionBrush" Value="{DynamicResource SelectedBrush}" />
        </Style>

        <!-- Title bar chrome buttons -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard Storyboard="{StaticResource ButtonHoverInStoryboard}" />
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard Storyboard="{StaticResource ButtonHoverOutStoryboard}" />
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseDown">
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressInStoryboard}" />
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseUp">
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressOutStoryboard}" />
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource CloseHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DialogDangerPressedBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark minimal scrollbars -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource ScrollBarThumbBrush}"
                                CornerRadius="4"
                                Margin="2" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="10" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ColumnHeaderBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark context menu (fixes default icon-column white stripe) -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource ContextMenuBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True"
                                        Background="Transparent"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="{DynamicResource SeparatorBrush}" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}"
                                Height="1"
                                SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Icon" Value="{x:Null}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <Grid Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  Margin="12,8"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer shell with glass background -->
    <Border Background="{DynamicResource GlassBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="10"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.45"
                              Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBackgroundBrush}"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <TextBlock Text="&#xE8B7;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="-90" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock x:Name="AppTitleText"
                                   Text="{loc:Loc UI_AppTitle}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button x:Name="TerminalToggleButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Content="&#xE756;"
                                ToolTip="Terminal"
                                Width="40"
                                FontSize="11"
                                Click="TerminalToggleButton_Click" />
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Content="&#xE713;"
                                ToolTip="Settings"
                                Width="40"
                                FontSize="11"
                                Click="SettingsButton_Click" />
                        <Button x:Name="AddPaneButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Content="&#xE710;"
                                ToolTip="Add directory pane"
                                Width="40"
                                FontSize="11"
                                Foreground="{DynamicResource AccentBrush}"
                                Click="AddPaneButton_Click" />
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Content="&#xE921;"
                                ToolTip="Minimize"
                                Click="MinimizeButton_Click" />
                        <Button x:Name="MaximizeButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Content="&#xE922;"
                                ToolTip="Maximize"
                                Click="MaximizeButton_Click" />
                        <Button Style="{StaticResource CloseButtonStyle}"
                                Content="&#xE8BB;"
                                ToolTip="Close"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Address bar, main content, dim layer, editor, and name prompt -->
            <Grid Grid.Row="1"
                  Grid.RowSpan="2"
                  x:Name="MainChromeHost"
                  ClipToBounds="True"
                  Margin="10,6,10,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition x:Name="TerminalSplitterRow" Height="0" MinHeight="0" MaxHeight="6" />
                    <RowDefinition x:Name="TerminalPanelRow" Height="0" MinHeight="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="200" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="280" />
                </Grid.ColumnDefinitions>

                    <!-- Navigation tree -->
                    <Border x:Name="NavigationPanel"
                            Grid.Row="0"
                            Grid.Column="0"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top"
                                       x:Name="NavigationLabelText"
                                       Text="{loc:Loc UI_Navigation}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="12,10,12,6" />
                            <TreeView x:Name="DirectoryTree"
                                      Margin="4,0,4,8"
                                      Background="Transparent"
                                      AlternationCount="0"
                                      AllowDrop="True"
                                      ItemContainerStyle="{DynamicResource ExplorerTreeViewItemStyle}"
                                      SelectedItemChanged="DirectoryTree_SelectedItemChanged"
                                      TreeViewItem.Expanded="DirectoryTreeItem_Expanded"
                                      DragOver="DirectoryTree_DragOver"
                                      Drop="DirectoryTree_Drop"
                                      PreviewMouseRightButtonDown="DirectoryTree_PreviewMouseRightButtonDown"
                                      ContextMenuOpening="DirectoryTree_ContextMenuOpening">
                                <TreeView.ContextMenu>
                                    <ContextMenu x:Name="DirectoryTreeContextMenu"
                                                 Opened="DirectoryTreeContextMenu_Opened">
                                        <MenuItem x:Name="DirectoryTreeOpenMenuItem"
                                                  Click="DirectoryTreeOpenMenuItem_Click" />
                                        <MenuItem x:Name="DirectoryTreeExpandMenuItem"
                                                  Click="DirectoryTreeExpandMenuItem_Click" />
                                        <MenuItem x:Name="DirectoryTreeReloadMenuItem"
                                                  Click="DirectoryTreeReloadMenuItem_Click" />
                                        <Separator x:Name="DirectoryTreeDriveSeparator" />
                                        <MenuItem x:Name="DirectoryTreeEjectMenuItem"
                                                  Click="DirectoryTreeEjectMenuItem_Click" />
                                        <MenuItem x:Name="DirectoryTreeRefreshDrivesMenuItem"
                                                  Click="DirectoryTreeRefreshDrivesMenuItem_Click" />
                                    </ContextMenu>
                                </TreeView.ContextMenu>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Icon}"
                                                   Width="16"
                                                   Height="16"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=Foreground}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Row="0"
                                  Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  Background="Transparent"
                                  ShowsPreview="True" />

                    <!-- Dynamic directory pane host -->
                    <Grid Grid.Row="0"
                          Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BackNavigationButton"
                                    Grid.Column="0"
                                    Style="{StaticResource NavButtonStyle}"
                                    Content="&#xE72B;"
                                    ToolTip="Back"
                                    IsEnabled="False"
                                    Click="BackNavigationButton_Click" />

                            <Button x:Name="ForwardNavigationButton"
                                    Grid.Column="1"
                                    Style="{StaticResource NavButtonStyle}"
                                    Content="&#xE72A;"
                                    ToolTip="Forward"
                                    IsEnabled="False"
                                    Click="ForwardNavigationButton_Click" />

                            <Button x:Name="HistoryNavigationButton"
                                    Grid.Column="2"
                                    Style="{StaticResource NavButtonStyle}"
                                    Content="&#xE81C;"
                                    ToolTip="History"
                                    Click="HistoryNavigationButton_Click" />

                            <Popup x:Name="HistoryPopup"
                                   PlacementTarget="{Binding ElementName=HistoryNavigationButton}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource AppPopupBackground}"
                                        BorderBrush="{DynamicResource AppPopupBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Width="420"
                                        MaxHeight="400"
                                        Padding="8"
                                        SnapsToDevicePixels="True">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" MinHeight="120" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="HistoryTitleText"
                                                   Text="Recent locations"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="4,2,4,8" />

                                        <ListBox x:Name="HistoryListBox"
                                                 Grid.Row="1"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 MouseLeftButtonUp="HistoryListBox_MouseLeftButtonUp">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="2,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Image Source="{Binding Icon}"
                                                               Width="16"
                                                               Height="16"
                                                               Margin="0,0,10,0"
                                                               VerticalAlignment="Top" />
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding Path}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       FontSize="10"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2"
                                                                    HorizontalAlignment="Right"
                                                                    Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding KindLabel}"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       FontSize="10"
                                                                       HorizontalAlignment="Right" />
                                                            <TextBlock Text="{Binding VisitedAtDisplay}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       FontSize="10"
                                                                       HorizontalAlignment="Right"
                                                                       Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <TextBlock x:Name="HistoryEmptyText"
                                                   Grid.Row="1"
                                                   Text="No recent folders or files yet."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="12"
                                                   Visibility="Collapsed" />

                                        <Button x:Name="HistoryClearButton"
                                                Grid.Row="2"
                                                Style="{StaticResource DialogActionButtonStyle}"
                                                Content="Clear history"
                                                HorizontalAlignment="Right"
                                                Margin="0,8,0,0"
                                                Click="HistoryClearButton_Click" />
                                    </Grid>
                                </Border>
                            </Popup>

                            <Button x:Name="BookmarksNavigationButton"
                                    Grid.Column="3"
                                    Style="{StaticResource NavButtonStyle}"
                                    Content="&#xE735;"
                                    ToolTip="Bookmarks"
                                    Click="BookmarksNavigationButton_Click" />

                            <Popup x:Name="BookmarksPopup"
                                   PlacementTarget="{Binding ElementName=BookmarksNavigationButton}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource AppPopupBackground}"
                                        BorderBrush="{DynamicResource AppPopupBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Width="380"
                                        MaxHeight="360"
                                        Padding="8"
                                        SnapsToDevicePixels="True">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" MinHeight="100" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="BookmarksTitleText"
                                                   Text="Bookmarks"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="4,2,4,8" />

                                        <ListBox x:Name="BookmarksListBox"
                                                 Grid.Row="1"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 MouseLeftButtonUp="BookmarksListBox_MouseLeftButtonUp">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="2,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Image Source="{Binding Icon}"
                                                               Width="16"
                                                               Height="16"
                                                               Margin="0,0,10,0"
                                                               VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding Path}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       FontSize="10"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <TextBlock x:Name="BookmarksEmptyText"
                                                   Grid.Row="1"
                                                   Text="No bookmarks yet."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="12"
                                                   Visibility="Collapsed" />

                                        <StackPanel Grid.Row="2"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,8,0,0">
                                            <Button x:Name="BookmarkAddCurrentButton"
                                                    Style="{StaticResource DialogActionButtonStyle}"
                                                    Content="Add current folder"
                                                    Margin="0,0,8,0"
                                                    Click="BookmarkAddCurrentButton_Click" />
                                            <Button x:Name="BookmarksClearButton"
                                                    Style="{StaticResource DialogActionButtonStyle}"
                                                    Content="Clear"
                                                    Click="BookmarksClearButton_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Popup>

                            <Button x:Name="ContentSearchButton"
                                    Grid.Column="4"
                                    Style="{StaticResource NavButtonStyle}"
                                    Content="&#xE721;"
                                    ToolTip="Search in folder"
                                    Click="ContentSearchButton_Click" />

                            <Button x:Name="PreviewToggleButton"
                                    Grid.Column="5"
                                    Style="{StaticResource NavButtonStyle}"
                                    Content="&#xE890;"
                                    ToolTip="Preview panel"
                                    Click="PreviewToggleButton_Click" />

                            <TextBlock x:Name="SearchingIndicator"
                                       Grid.Column="7"
                                       Text="Searching..."
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       Visibility="Collapsed" />

                            <TextBlock x:Name="ExtractingIndicator"
                                       Grid.Column="7"
                                       Text="Extracting..."
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       Visibility="Collapsed" />
                            </Grid>

                            <Border x:Name="ContentSearchPanel"
                                    Grid.Row="1"
                                    Margin="0,0,0,8"
                                    Background="{DynamicResource PanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="Collapsed"
                                    MaxHeight="220">
                                <DockPanel LastChildFill="True" Margin="8">
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ContentSearchBox"
                                                 Style="{DynamicResource AddressBarTextBoxStyle}"
                                                 KeyDown="ContentSearchBox_KeyDown" />
                                        <Button x:Name="ContentSearchCloseButton"
                                                Grid.Column="1"
                                                Style="{StaticResource DialogActionButtonStyle}"
                                                Content="Close"
                                                Margin="8,0,0,0"
                                                Click="ContentSearchCloseButton_Click" />
                                    </Grid>
                                    <ListBox x:Name="ContentSearchResultsList"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             MouseDoubleClick="ContentSearchResultsList_MouseDoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2,4">
                                                    <TextBlock Text="{Binding RelativePath}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="10"
                                                               TextTrimming="CharacterEllipsis">
                                                        <Run Text="{Binding LineNumber, StringFormat='Line {0}: '}" />
                                                        <Run Text="{Binding LineText}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <Grid x:Name="PaneHostContainer"
                              Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="240" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition x:Name="PreviewPanelColumn" Width="280" MinWidth="180" />
                            </Grid.ColumnDefinitions>

                            <controls:DirectoryPaneHost x:Name="DirectoryPaneHost"
                                                        Grid.Column="0" />

                            <GridSplitter x:Name="PreviewPanelSplitter"
                                          Grid.Column="1"
                                          Width="6"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Stretch"
                                          Background="Transparent"
                                          ShowsPreview="True" />

                            <controls:FilePreviewPanel x:Name="FilePreviewPanelControl"
                                                       Grid.Column="2" />
                        </Grid>
                    </Grid>
                <!-- Dimming layer (shared by editor, dialogs) -->
                <Border x:Name="ChromeDimOverlay"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        Grid.ColumnSpan="3"
                        Panel.ZIndex="250"
                        Background="{DynamicResource DimOverlayBrush}"
                        Opacity="0"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        CornerRadius="8" />

                <!-- Built-in editor overlay -->
                <Border x:Name="EditorOverlay"
                        Grid.Row="0"
                        Grid.Column="2"
                        Panel.ZIndex="280"
                        Visibility="Collapsed"
                        RenderTransformOrigin="0.5,0.5"
                        Margin="4,8,4,8"
                        Background="{DynamicResource ModalPanelBackgroundBrush}"
                        CornerRadius="6"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource OverlayHeaderBrush}"
                                CornerRadius="6,6,0,0"
                                Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#xE943;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock x:Name="EditorFileNameText"
                                               Text="Untitled"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="EditorDirtyIndicator"
                                               Text=" *"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Visibility="Collapsed" />
                                </StackPanel>

                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="EditorSaveButton"
                                            Grid.Column="0"
                                            Style="{StaticResource EditorActionButtonStyle}"
                                            Content="{loc:Loc UI_Save}"
                                            Click="EditorSaveButton_Click" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource EditorActionButtonStyle}"
                                            Content="{loc:Loc UI_Close}"
                                            Click="EditorCloseButton_Click" />
                                </Grid>
                            </Grid>
                        </Border>

                        <TextBox x:Name="EditorTextBox"
                                 Grid.Row="1"
                                 Style="{StaticResource EditorTextBoxStyle}"
                                 TextChanged="EditorTextBox_TextChanged"
                                 PreviewKeyDown="EditorTextBox_PreviewKeyDown" />
                    </Grid>
                </Border>

                <!-- Archive viewer overlay -->
                <Border x:Name="ArchiveOverlay"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Panel.ZIndex="300"
                        Visibility="Collapsed"
                        Background="Transparent"
                        IsHitTestVisible="True">
                    <Border RenderTransformOrigin="0.5,0.5"
                            Margin="4,8,4,8"
                            Background="{DynamicResource ModalPanelBackgroundBrush}"
                            CornerRadius="6"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource OverlayHeaderBrush}"
                                CornerRadius="6,6,0,0"
                                Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8B7;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock x:Name="ArchiveFileNameText"
                                               Text="archive.zip"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="ArchiveExtractButton"
                                            Grid.Column="0"
                                            Style="{StaticResource EditorActionButtonStyle}"
                                            Content="{loc:Loc UI_ExtractHere}"
                                            Click="ArchiveExtractButton_Click" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource EditorActionButtonStyle}"
                                            Content="{loc:Loc UI_Close}"
                                            Click="ArchiveCloseButton_Click" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <ListView x:Name="ArchiveContentsList"
                                      Margin="4,4,4,4"
                                      SelectionMode="Extended"
                                      ItemContainerStyle="{DynamicResource ExplorerListViewItemStyle}"
                                      ContextMenuOpening="ArchiveContentsList_ContextMenuOpening">
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem x:Name="ArchiveExtractSelectedMenuItem"
                                                  Header="{loc:Loc UI_ExtractSelected}"
                                                  Tag="ExtractSelected"
                                                  Click="ExtractSelectedArchiveEntry_Click" />
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn x:Name="ArchiveFileNameColumn" Header="File Name" Width="260">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="ArchiveOriginalSizeColumn" Header="Original Size" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding OriginalSizeDisplay}"
                                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                               HorizontalAlignment="Right" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="ArchiveCompressedSizeColumn" Header="Compressed Size" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding CompressedSizeDisplay}"
                                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                               HorizontalAlignment="Right" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <TextBlock x:Name="ArchiveErrorText"
                                       Text="{loc:Loc UI_ArchiveError}"
                                       Foreground="{DynamicResource ErrorTextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="20"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Grid>
                    </Border>
                </Border>

                <!-- Media viewer overlay -->
                <Border x:Name="MediaViewerOverlay"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        Grid.ColumnSpan="3"
                        Panel.ZIndex="295"
                        Visibility="Collapsed"
                        Background="#D9000000"
                        IsHitTestVisible="True"
                        MouseLeftButtonDown="MediaViewerOverlay_MouseLeftButtonDown">
                    <Border x:Name="MediaViewerPanel"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5"
                            Background="{DynamicResource ModalPanelBackgroundBrush}"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            MouseLeftButtonDown="MediaViewerPanel_MouseLeftButtonDown">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{DynamicResource OverlayHeaderBrush}"
                                    CornerRadius="8,8,0,0"
                                    Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE714;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="16"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0" />
                                        <TextBlock x:Name="MediaViewerFileNameText"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource EditorActionButtonStyle}"
                                            x:Name="MediaViewerCloseButton"
                                            Content="{loc:Loc UI_Close}"
                                            Click="MediaViewerCloseButton_Click" />
                                </Grid>
                            </Border>

                            <Grid x:Name="MediaViewerContentGrid" Grid.Row="1" Margin="0">
                                <Border x:Name="MediaViewerImageHost"
                                        Visibility="Collapsed"
                                        Background="#000000"
                                        CornerRadius="0">
                                    <Image x:Name="MediaViewerImage"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>

                                <Grid x:Name="MediaViewerVideoHost" Visibility="Collapsed">
                                    <MediaElement x:Name="MediaViewerPlayer"
                                                  LoadedBehavior="Manual"
                                                  UnloadedBehavior="Stop"
                                                  Stretch="Uniform"
                                                  ScrubbingEnabled="True"
                                                  MediaOpened="MediaViewerPlayer_MediaOpened"
                                                  MediaEnded="MediaViewerPlayer_MediaEnded"
                                                  MediaFailed="MediaViewerPlayer_MediaFailed" />
                                    <wv2:WebView2 x:Name="MediaViewerWebPlayer"
                                                  Visibility="Collapsed"
                                                  DefaultBackgroundColor="#0B0B0B" />
                                </Grid>
                            </Grid>

                            <StackPanel x:Name="MediaViewerControlsPanel"
                                        Grid.Row="2"
                                        Visibility="Collapsed"
                                        Margin="12,0,12,8">
                                <Slider x:Name="MediaViewerPositionSlider"
                                        Style="{StaticResource ExplorerSliderStyle}"
                                        Minimum="0"
                                        Maximum="1"
                                        Margin="0,0,0,8"
                                        Thumb.DragStarted="MediaViewerPositionSlider_DragStarted"
                                        Thumb.DragCompleted="MediaViewerPositionSlider_DragCompleted" />
                                <Grid>
                                    <TextBlock x:Name="MediaViewerTimeText"
                                               Text="0:00 / 0:00"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="11"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="MediaViewerPlayPauseButton"
                                            Style="{StaticResource EditorActionButtonStyle}"
                                            HorizontalAlignment="Right"
                                            Click="MediaViewerPlayPauseButton_Click" />
                                </Grid>
                            </StackPanel>

                            <TextBlock x:Name="MediaViewerErrorText"
                                       Grid.Row="3"
                                       Foreground="#FFFF6B6B"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="12,0,12,12"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Border>
                </Border>

                <!-- Custom name prompt -->
                <Border x:Name="NamePromptOverlay"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        Grid.ColumnSpan="3"
                        Panel.ZIndex="300"
                        Visibility="Collapsed"
                        Background="Transparent"
                        IsHitTestVisible="True">
                    <Border Width="360"
                            x:Name="NamePromptPanel"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource GlassBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <StackPanel Background="Transparent">
                            <TextBlock x:Name="NamePromptTitleText"
                                       Text="New item"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <ListView x:Name="GitCommitFilesList"
                                      Height="140"
                                      Margin="0,0,0,12"
                                      Background="{DynamicResource PanelBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrushDark}"
                                      BorderThickness="1"
                                      Visibility="Collapsed"
                                      ItemContainerStyle="{DynamicResource ExplorerListViewItemStyle}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Margin="4,0,10,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Modified">
                                                                <Setter Property="Fill" Value="{DynamicResource GitModifiedBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Added">
                                                                <Setter Property="Fill" Value="{DynamicResource GitAddedBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Untracked">
                                                                <Setter Property="Fill" Value="{DynamicResource GitUntrackedBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Deleted">
                                                                <Setter Property="Fill" Value="{DynamicResource GitDeletedBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="UpdatedButUnmerged">
                                                                <Setter Property="Fill" Value="{DynamicResource GitConflictBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBox x:Name="NamePromptTextBox"
                                     Style="{DynamicResource AddressBarTextBoxStyle}"
                                     KeyDown="NamePromptTextBox_KeyDown" />
                            <TextBlock x:Name="NamePromptErrorText"
