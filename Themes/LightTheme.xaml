<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- System selection overrides -->
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#331A86E0" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1A1A1A" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#221A86E0" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1A1A1A" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#1A1A1A" />

    <!-- Frosted glass palette -->
    <SolidColorBrush x:Key="GlassBackgroundBrush" Color="#D9F4F6FA" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#B3FFFFFF" />
    <SolidColorBrush x:Key="BorderBrushDark" Color="#33000000" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5C5C5C" />
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="HoverBrush" Color="#18000000" />
    <SolidColorBrush x:Key="SelectionFillBrush" Color="#331A86E0" />
    <SolidColorBrush x:Key="SelectionFillHoverBrush" Color="#441A86E0" />
    <SolidColorBrush x:Key="SelectionFillInactiveBrush" Color="#221A86E0" />
    <SolidColorBrush x:Key="SelectionBorderBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="SelectionBorderInactiveBrush" Color="#660078D4" />
    <SolidColorBrush x:Key="SelectionForegroundBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="SelectedBrush" Color="#331A86E0" />
    <SolidColorBrush x:Key="AddressBarBackgroundBrush" Color="#33FFFFFF" />

    <!-- Settings / form controls -->
    <SolidColorBrush x:Key="AppControlBackground" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="AppTextForeground" Color="#1A1A1A" />
    <SolidColorBrush x:Key="AppControlBorderBrush" Color="#33000000" />
    <SolidColorBrush x:Key="AppControlHoverBackground" Color="#18000000" />
    <SolidColorBrush x:Key="AppControlPressedBackground" Color="#2A000000" />
    <SolidColorBrush x:Key="AppPopupBackground" Color="#F0FFFFFF" />
    <SolidColorBrush x:Key="AppPopupBorderBrush" Color="#33000000" />

    <!-- Chrome / overlay accents -->
    <SolidColorBrush x:Key="CloseHoverBrush" Color="#E81123" />
    <SolidColorBrush x:Key="DimOverlayBrush" Color="#66000000" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="OverlayHeaderBrush" Color="#44FFFFFF" />
    <SolidColorBrush x:Key="ButtonChromeBrush" Color="#22000000" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#33000000" />
    <SolidColorBrush x:Key="DialogButtonBrush" Color="#2A000000" />
    <SolidColorBrush x:Key="DialogButtonHoverBrush" Color="#44000000" />
    <SolidColorBrush x:Key="DialogDangerBrush" Color="#55E81123" />
    <SolidColorBrush x:Key="DialogDangerHoverBrush" Color="#88E81123" />
    <SolidColorBrush x:Key="DialogDangerPressedBrush" Color="#C50F1F" />
    <SolidColorBrush x:Key="ContextMenuBackgroundBrush" Color="#F0FFFFFF" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="#33000000" />
    <SolidColorBrush x:Key="ColumnHeaderBackgroundBrush" Color="#22000000" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#55000000" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="ErrorTextBrush" Color="#FFD13438" />
    <SolidColorBrush x:Key="PaneInactiveBorderBrush" Color="#33000000" />
    <SolidColorBrush x:Key="SplitterIdleBrush" Color="#18000000" />
    <SolidColorBrush x:Key="SplitterHoverBrush" Color="#550078D4" />
    <SolidColorBrush x:Key="ShadowColor" Color="#66000000" />

    <!-- Animation / selection color tokens -->
    <Color x:Key="TransparentFillColor">#00000000</Color>
    <Color x:Key="HoverFillColor">#18000000</Color>
    <Color x:Key="SelectionFillColor">#331A86E0</Color>
    <Color x:Key="SelectionFillHoverColor">#441A86E0</Color>
    <Color x:Key="SelectionBorderColor">#0078D4</Color>

</ResourceDictionary>
