                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   Margin="0,0,0,8" />
                                        <TextBlock x:Name="SettingsSupportAddressLabel"
                                                   Text="{loc:Loc UI_SupportWalletAddress}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
