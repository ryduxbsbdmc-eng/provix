                                <Border Background="{DynamicResource OpaqueInputBackgroundBrush}"
                                        BorderBrush="{DynamicResource SelectionBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="SettingsSupportTokenText"
