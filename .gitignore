# =============================================================================
# Provix / FileExplorer — keep secrets and machine-specific files out of git
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets, credentials, API keys (never commit these)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

*.pem
*.key
*.pfx
*.p12
*.cer
*.crt
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

secrets/
.secrets/
credentials/
credentials.json
*credentials*.json
*secrets*.json
appsettings.local.json
appsettings.*.local.json
appsettings.Development.json
settings.json
settings.local.json
**/FileExplorer/settings.json
openrouter.key
*.token

