<UserControl x:Class="FileExplorer.Controls.FilePreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:FileExplorer.Markup"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             MinWidth="180">
    <Border Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="8">
        <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" Margin="10,8,10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="PreviewTitleText"
                           Text="{loc:Loc UI_Preview}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button x:Name="ClosePreviewButton"
                        Grid.Column="1"
                        Width="24"
                        Height="24"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="10"
                        Content="&#xE8BB;"
                        Cursor="Hand"
                        Click="ClosePreviewButton_Click" />
            </Grid>

            <TextBlock x:Name="PreviewFileNameText"
                       DockPanel.Dock="Top"
                       Margin="10,0,10,4"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" />

            <TextBlock x:Name="PreviewSubtitleText"
                       DockPanel.Dock="Top"
                       Margin="10,0,10,8"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="10"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap" />

            <Grid>
                <ScrollViewer x:Name="ImagePreviewScroller"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="8,0,8,8">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"
                           MaxHeight="360"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </ScrollViewer>

                <ScrollViewer x:Name="TextPreviewScroller"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="8,0,8,8">
                    <TextBlock x:Name="PreviewTextBlock"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </ScrollViewer>

                <wv2:WebView2 x:Name="PreviewWebView"
                              Visibility="Collapsed"
                              Margin="4,0,4,4" />

                <TextBlock x:Name="PreviewEmptyText"
                           Text="{loc:Loc UI_PreviewEmpty}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="12" />
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
