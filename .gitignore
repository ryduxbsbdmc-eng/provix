.cursor/*
!.cursor/rules/
!.cursor/rules/**

# -----------------------------------------------------------------------------
# OS & sync junk
# -----------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
[Dd]esktop.ini

.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# OneDrive / cloud sync conflict copies
*~$*
*.tmp
*.temp
*.swp
*.swo
*conflict*
*.sync-conflict-*

# -----------------------------------------------------------------------------
# Test, coverage, profiling
# -----------------------------------------------------------------------------
[Cc]overage/
*.coverage
*.coveragexml
*.dotCover
.axoCover/
[Bb]enchmark[Dd]ot[Nn]et.Artifacts/

# -----------------------------------------------------------------------------
# Archives & dumps (often contain private data)
# -----------------------------------------------------------------------------
*.zip
*.7z
*.rar
*.tar
*.gz
*.bak
*.backup
*.old
*.dump
*.dmp
memory.dmp

# Keep locale/source archives out; add exceptions below if you ship assets
# !Assets/**/*.zip

# -----------------------------------------------------------------------------
# Python (if you add scripts later)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/

