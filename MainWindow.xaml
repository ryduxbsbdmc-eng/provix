                        </ScrollViewer>
                    </Border>
                </Border>

                <!-- Icon pack editor -->
                <Border x:Name="IconPackEditorOverlay"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        Grid.ColumnSpan="3"
                        Panel.ZIndex="410"
                        Visibility="Collapsed"
                        Background="#D9000000"
                        IsHitTestVisible="True"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True"
                        MouseLeftButtonDown="IconPackEditorOverlay_MouseLeftButtonDown">
                    <Border x:Name="IconPackEditorPanel"
                            Width="560"
                            MaxHeight="640"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5"
                            Background="{DynamicResource AppPopupBackground}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True"
                            MouseLeftButtonDown="IconPackEditorPanel_MouseLeftButtonDown">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      helpers:SmoothScrollHelper.IsEnabled="True">
                            <StackPanel>
                                <TextBlock x:Name="IconPackEditorTitleText"
                                           Text="{loc:Loc UI_IconPackEditorTitle}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12" />

                                <TextBlock x:Name="IconPackNameLabel"
                                           Text="{loc:Loc UI_IconPackName}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,4" />
                                <TextBox x:Name="IconPackNameTextBox"
                                         Style="{StaticResource AddressBarTextBoxStyle}"
                                         Margin="0,0,0,10"
                                         TextChanged="IconPackNameTextBox_TextChanged" />

                                <TextBlock x:Name="IconPackFolderLabel"
                                           Text="{loc:Loc UI_IconPackFolder}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,4" />
                                <TextBox x:Name="IconPackFolderTextBox"
                                         Style="{StaticResource AddressBarTextBoxStyle}"
                                         IsReadOnly="True"
                                         Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="IconPackNewButton"
                                            Style="{StaticResource DialogActionButtonStyle}"
                                            Margin="0,0,8,0"
                                            Click="IconPackNewButton_Click" />
                                    <Button x:Name="IconPackOpenButton"
                                            Style="{StaticResource DialogActionButtonStyle}"
                                            Click="IconPackOpenButton_Click" />
                                </StackPanel>

                                <TextBlock x:Name="IconPackSystemIconsLabel"
                                           Text="{loc:Loc UI_IconPackSystemIcons}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="IconPackFolderIconLabel"
                                               Grid.Column="0"
                                               Text="{loc:Loc UI_IconPackFolderIcon}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="12" />
                                    <Image x:Name="IconPackFolderPreview"
                                           Grid.Column="1"
                                           Width="32"
                                           Height="32"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Button x:Name="IconPackChooseFolderIconButton"
                                            Grid.Column="2"
                                            Style="{StaticResource DialogActionButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Margin="8,0,0,0"
                                            Click="IconPackChooseFolderIconButton_Click" />
                                </Grid>

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="IconPackFileIconLabel"
                                               Grid.Column="0"
                                               Text="{loc:Loc UI_IconPackFileIcon}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="12" />
                                    <Image x:Name="IconPackFilePreview"
                                           Grid.Column="1"
                                           Width="32"
                                           Height="32"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Button x:Name="IconPackChooseFileIconButton"
                                            Grid.Column="2"
                                            Style="{StaticResource DialogActionButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Margin="8,0,0,0"
                                            Click="IconPackChooseFileIconButton_Click" />
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="IconPackDriveIconLabel"
                                               Grid.Column="0"
                                               Text="{loc:Loc UI_IconPackDriveIcon}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="12" />
                                    <Image x:Name="IconPackDrivePreview"
                                           Grid.Column="1"
                                           Width="32"
                                           Height="32"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Button x:Name="IconPackChooseDriveIconButton"
                                            Grid.Column="2"
                                            Style="{StaticResource DialogActionButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Margin="8,0,0,0"
                                            Click="IconPackChooseDriveIconButton_Click" />
                                </Grid>

                                <TextBlock x:Name="IconPackExtensionsLabel"
                                           Text="{loc:Loc UI_IconPackExtensions}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBox x:Name="IconPackNewExtensionTextBox"
                                             Style="{StaticResource AddressBarTextBoxStyle}"
                                             Width="120"
                                             Margin="0,0,8,0" />
                                    <Button x:Name="IconPackAddExtensionButton"
                                            Style="{StaticResource DialogActionButtonStyle}"
                                            Click="IconPackAddExtensionButton_Click" />
                                </StackPanel>

                                <ListView x:Name="IconPackMappingsList"
                                          Height="140"
                                          Margin="0,0,0,8">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn x:Name="IconPackExtensionColumn"
                                                            Header="Extension"
                                                            Width="90"
                                                            DisplayMemberBinding="{Binding Extension}" />
                                            <GridViewColumn x:Name="IconPackImageColumn"
                                                            Header="Image"
                                                            Width="180"
                                                            DisplayMemberBinding="{Binding ImageFileName}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                                <Button x:Name="IconPackRemoveExtensionButton"
                                        Style="{StaticResource DialogActionButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,12"
                                        Click="IconPackRemoveExtensionButton_Click" />

                                <TextBlock x:Name="IconPackEditorErrorText"
                                           Foreground="#FFFF6B6B"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"
                                           Margin="0,0,0,8" />

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="IconPackSaveButton"
                                            Style="{StaticResource DialogActionButtonStyle}"
                                            Margin="0,0,8,0"
                                            Click="IconPackSaveButton_Click" />
                                    <Button x:Name="IconPackApplyButton"
                                            Style="{StaticResource DialogActionButtonStyle}"
                                            Margin="0,0,8,0"
                                            Click="IconPackApplyButton_Click" />
                                    <Button x:Name="IconPackCancelButton"
                                            Style="{StaticResource DialogActionButtonStyle}"
                                            Click="IconPackCancelButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Border>

                <!-- Git commit history & restore -->
                <Border x:Name="CommitHistoryOverlay"
                        Grid.Row="0"
                        Grid.ColumnSpan="3"
                        Visibility="Collapsed"
                        Background="Transparent"
                        IsHitTestVisible="True">
                    <Grid>
                        <Border x:Name="CommitHistoryPanel"
                                Width="560"
                                MaxHeight="520"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5"
                                Background="{DynamicResource GlassBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="18"
                                SnapsToDevicePixels="True">
                            <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="CommitHistoryTitleText"
                                       Grid.Row="0"
                                       Text="{loc:Loc UI_GitVersionHistory}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />

                            <Border Grid.Row="1"
                                    Background="{DynamicResource PanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,0,0,12"
                                    MinHeight="220"
                                    MaxHeight="360">
                                <ListBox x:Name="CommitHistoryListBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         ItemContainerStyle="{DynamicResource CommitHistoryListBoxItemStyle}"
                                         SelectionChanged="CommitHistoryListBox_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock FontSize="12">
                                                    <Run Text="{Binding Hash}"
                                                         FontWeight="SemiBold"
                                                         FontFamily="Consolas" />
                                                    <Run Text="  В·  " />
                                                    <Run Text="{Binding Date}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding Message}"
                                                           FontSize="12"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap"
                                                           Opacity="0.92" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <TextBlock x:Name="CommitHistoryWarningText"
                                       Grid.Row="2"
                                       Text="{loc:Loc UI_GitRestoreWarning}"
                                       TextWrapping="Wrap"
                                       Foreground="#FFFFB86B"
                                       FontSize="12"
                                       LineHeight="18"
                                       Margin="0,0,0,10"
                                       Visibility="Collapsed" />

                            <TextBlock x:Name="CommitHistoryErrorText"
                                       Grid.Row="3"
                                       Foreground="{DynamicResource ErrorTextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"
                                       Margin="0,0,0,8" />

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="2"
                                        x:Name="CommitHistoryCancelButton"
                                        Style="{StaticResource DialogActionButtonStyle}"
                                        Content="{loc:Loc UI_Cancel}"
                                        Click="CommitHistoryCancelButton_Click" />
                                <Button Grid.Column="4"
                                        x:Name="CommitHistoryDeleteCommitButton"
                                        Style="{StaticResource DialogDeleteCommitButtonStyle}"
                                        IsEnabled="False"
                                        Click="CommitHistoryDeleteCommitButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{loc:Loc UI_GitDeleteCommit}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="6"
                                        x:Name="CommitHistoryRestoreButton"
                                        Style="{StaticResource DialogActionButtonStyle}"
                                        Content="{loc:Loc UI_GitRestoreSelected}"
                                        IsEnabled="False"
                                        Click="CommitHistoryRestoreButton_Click" />
                                <Button Grid.Column="6"
                                        x:Name="CommitHistoryConfirmRestoreButton"
                                        Style="{StaticResource DialogDangerButtonStyle}"
                                        Content="{loc:Loc UI_GitConfirmRestore}"
                                        Visibility="Collapsed"
                                        Click="CommitHistoryConfirmRestoreButton_Click" />
                            </Grid>
                            </Grid>
                        </Border>

                        <Border x:Name="CommitDeleteConfirmOverlay"
                                Visibility="Collapsed"
                                Background="#99000000"
                                SnapsToDevicePixels="True">
                            <Border Width="400"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource GlassBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="18"
                                    SnapsToDevicePixels="True">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc UI_GitDeleteCommitTitle}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,10" />
                                    <TextBlock Text="{loc:Loc UI_GitDeleteCommitMessage}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="13"
                                               LineHeight="20"
                                               Margin="0,0,0,14" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="2"
                                                x:Name="CommitDeleteConfirmCancelButton"
                                                Style="{StaticResource DialogActionButtonStyle}"
                                                Content="{loc:Loc UI_Cancel}"
                                                Click="CommitDeleteConfirmCancelButton_Click" />
                                        <Button Grid.Column="4"
                                                x:Name="CommitDeleteConfirmYesButton"
                                                Style="{StaticResource DialogDangerButtonStyle}"
                                                Content="{loc:Loc UI_GitDeleteCommitYes}"
                                                Click="CommitDeleteConfirmYesButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="FolderCompareOverlay"
                        Grid.Row="0"
                        Grid.Column="2"
                        Panel.ZIndex="290"
                        Visibility="Collapsed"
                        Margin="4,8,4,8"
                        Background="{DynamicResource ModalPanelBackgroundBrush}"
                        CornerRadius="6"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F1;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock x:Name="FolderCompareTitleText"
                                           Text="Compare folders"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="FolderComparePathsText"
                                       Margin="26,8,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ListView x:Name="FolderCompareList"
                                  Grid.Row="1"
                                  Margin="0,12,0,0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  MinHeight="200"
                                  MaxHeight="420">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn x:Name="FolderCompareNameColumn" Header="Name" Width="220" DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn x:Name="FolderCompareLeftColumn" Header="Left" Width="100" DisplayMemberBinding="{Binding LeftDisplay}" />
                                    <GridViewColumn x:Name="FolderCompareRightColumn" Header="Right" Width="100" DisplayMemberBinding="{Binding RightDisplay}" />
                                    <GridViewColumn x:Name="FolderCompareStatusColumn" Header="Status" Width="120" DisplayMemberBinding="{Binding StatusDisplay}" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <Button x:Name="FolderCompareCloseButton"
                                Grid.Row="2"
                                Style="{StaticResource DialogActionButtonStyle}"
                                Content="Close"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0"
                                Click="FolderCompareCloseButton_Click" />
                    </Grid>
                </Border>

                <!-- Delete confirmation dialog -->
                <Border x:Name="DeleteConfirmOverlay"
                        Grid.Row="0"
                        Grid.ColumnSpan="3"
                        Visibility="Collapsed"
                        Background="Transparent"
                        IsHitTestVisible="True">
                    <Border x:Name="DeleteConfirmPanel"
                            Width="400"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5"
                            Background="{DynamicResource GlassBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="18"
                            SnapsToDevicePixels="True">
                        <StackPanel Background="Transparent">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,10">
                                <TextBlock Text="&#xE74D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="#FFFF6B6B"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock x:Name="DeleteConfirmTitleText"
                                           Text="{loc:Loc UI_DeleteItem}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="DeleteConfirmMessageText"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       LineHeight="20"
                                       Margin="0,0,0,8" />
                            <TextBlock x:Name="DeleteConfirmErrorText"
                                       Foreground="{DynamicResource ErrorTextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"
                                       Margin="0,0,0,4" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="2"
                                        x:Name="DeleteConfirmCancelButton"
                                        Style="{StaticResource DialogActionButtonStyle}"
                                        Content="{loc:Loc UI_Cancel}"
                                        Click="DeleteConfirmCancelButton_Click" />
                                <Button Grid.Column="4"
                                        x:Name="DeleteConfirmDeleteButton"
                                        Style="{StaticResource DialogDangerButtonStyle}"
                                        Content="{loc:Loc UI_Delete}"
                                        Click="DeleteConfirmDeleteButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>

                    <GridSplitter x:Name="TerminalSplitter"
                                  Grid.Row="1"
                                  Grid.ColumnSpan="3"
                                  Panel.ZIndex="20"
                                  Height="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="Transparent"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="True"
                                  Visibility="Collapsed" />

                    <controls:PowerShellTerminalControl x:Name="PowerShellTerminal"
                                                        Grid.Row="2"
                                                        Grid.ColumnSpan="3"
                                                        Panel.ZIndex="20"
                                                        Visibility="Collapsed"
                                                        CloseRequested="PowerShellTerminal_CloseRequested"
                                                        WorkingDirectoryChanged="PowerShellTerminal_WorkingDirectoryChanged" />
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="3"
                    Background="{DynamicResource StatusBarBackgroundBrush}"
                    CornerRadius="0,0,10,10"
                    Padding="14,6">
                <TextBlock x:Name="StatusText"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11" />
            </Border>
        </Grid>
    </Border>
</Window>
